# Без листинга каталогов (+FollowSymLinks часто нужен для mod_rewrite)
Options +FollowSymLinks -Indexes

# Сжатие ответов (меньше трафика для HTML/CSS/JS/JSON/SVG)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css
  AddOutputFilterByType DEFLATE application/javascript application/json application/xml
  AddOutputFilterByType DEFLATE image/svg+xml
</IfModule>

# Кэш: CSS/JS с ?v=mtime в URL — год и immutable; остальная статика — неделя
<IfModule mod_headers.c>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(ico|svg|png|jpg|jpeg|webp|gif|woff2)$">
    Header set Cache-Control "public, max-age=604800"
  </FilesMatch>
  # Базовая защита заголовками (не заменяет настройки на уровне сервера)
  Header always unset X-Powered-By
  Header unset X-Powered-By
  Header always set X-Content-Type-Options "nosniff"
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=(), usb=(), interest-cohort=()"
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains" env=HTTPS
</IfModule>

# Страницы ошибок (пути от корня DocumentRoot; в подкаталоге добавьте префикс, напр. /site/pages/http_error.php)
<IfModule mod_alias.c>
  ErrorDocument 400 /pages/http_error.php?c=400
  ErrorDocument 401 /pages/http_error.php?c=401
  ErrorDocument 403 /pages/http_error.php?c=403
  ErrorDocument 404 /pages/http_error.php?c=404
  ErrorDocument 500 /pages/http_error.php?c=500
  ErrorDocument 502 /pages/http_error.php?c=502
  ErrorDocument 503 /pages/http_error.php?c=503
</IfModule>

# Прямой HTTP-доступ к секретам и конфигам (дублирует правила ниже для надёжности)
<IfModule mod_authz_core.c>
  <FilesMatch "(?i)^(\.env(\..+)?|\.git.*|\.ht(access|passwd|users)|\.user\.ini|\.DS_Store|composer\.(json|lock)|package(-lock)?\.json|yarn\.lock|\.npmrc|web\.config)$">
    Require all denied
  </FilesMatch>
</IfModule>

# Запрет прямого доступа к JSON с OTP, пользователями и кэшем
<IfModule mod_rewrite.c>
  RewriteEngine On
  # Запрет TRACE/TRACK (утечки заголовков / устаревшие методы)
  RewriteCond %{REQUEST_METHOD} ^(TRACE|TRACK)$ [NC]
  RewriteRule .* - [F,L]
  # HTTP → HTTPS (301). За прокси с SSL смотрите X-Forwarded-Proto. Локально без SSL — закомментируйте блок.
  RewriteCond %{HTTP_HOST} !^localhost(:\d+)?$ [NC]
  RewriteCond %{HTTP_HOST} !^127\.0\.0\.1(:\d+)?$ [NC]
  RewriteCond %{HTTPS} !=on
  RewriteCond %{HTTP:X-Forwarded-Proto} !https [NC]
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301,QSA]
  # Главная без index.php в URL (корень домена; в подкаталоге задайте RewriteBase)
  RewriteCond %{THE_REQUEST} \s/+index\.php(\?|\s) [NC]
  RewriteRule ^index\.php$ / [R=301,L,QSA]

  # Служебные каталоги: только require/include из PHP, не из браузера
  RewriteRule ^app/ - [F,L]
  RewriteRule ^partials/ - [F,L]
  RewriteRule ^lang/ - [F,L]
  RewriteRule ^scripts/ - [F,L]
  RewriteRule ^PHPMailer/ - [F,L]

  # Скрытые файлы и каталоги (.git, .env, …). Исключение: /.well-known/ (SSL, верификации)
  RewriteCond %{REQUEST_URI} !\.well-known/ [NC]
  RewriteRule (^|/)\. - [F,L]

  # Резервные копии, логи, служебные скрипты в URL (не обычные страницы сайта)
  RewriteRule \.(bak|backup|old|orig|sql|log|swp|tmp|dist|sh|py)$ - [F,L,NC]

  # Реферальная ссылка: /r/КОД → регистрация с ref (короткий путь)
  RewriteRule ^r/([a-zA-Z0-9]{8,20})/?$ pages/register.php?ref=$1 [L,QSA]
  RewriteRule ^data/ - [F,L]
</IfModule>
